{
  "name": "bamboo-app",
  "private": true,
  "scripts": {
    "dev": "granite dev",
    "dev:reset": "bash -c 'rm -rf /tmp/metro-* node_modules/.cache 2>/dev/null' && npm run dev",
    "android:connect": "bash scripts/android-connect.sh",
    "android:open": "adb shell am start -a android.intent.action.VIEW -d \"intoss://bamboo-app\"",
    "android:devices": "adb devices -l",
    "build": "ait build",
    "test:setup": "npm run android:connect && npm run android:open",
    "debug:android": "bash scripts/debug-android.sh",
    "debug:android:logs": "bash scripts/debug-android-logs.sh",
    "debug:android:errors": "bash scripts/debug-android-errors.sh",
    "test": "jest --passWithNoTests",
    "test:checklist": "jest --testPathPattern=release-checklist --passWithNoTests",
    "checklist:bundle": "npm run build && npm run test:checklist",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write",
    "postinstall": "node scripts/patch-granite-rn.js"
  },
  "dependencies": {
    "@apps-in-toss/framework": "^2.0.5",
    "@granite-js/native": "1.0.4",
    "@granite-js/plugin-env": "1.0.4",
    "@granite-js/react-native": "1.0.4",
    "@toss/tds-react-native": "2.0.2",
    "brick-module": "0.5.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "firebase": "^12.10.0",
    "react": "19.2.3",
    "react-native": "0.84.0",
    "react-native-screens": "4.24.0",
    "stream-browserify": "^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "7.28.5",
    "@babel/runtime": "7.28.4",
    "@biomejs/biome": "^1.9.4",
    "@granite-js/plugin-hermes": "1.0.4",
    "@granite-js/plugin-router": "1.0.4",
    "@testing-library/react-native": "^12.9.0",
    "@types/babel__core": "^7.20.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.15",
    "@types/react": "19.2.3",
    "babel-preset-granite": "1.0.3",
    "jest": "^29.7.0",
    "patch-package": "^8.0.1",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "react-native-screens": "4.24.0",
    "@granite-js/native": {
      "react-native-screens": "4.24.0"
    },
    "@react-navigation/native-stack": {
      "react-native-screens": "4.24.0"
    }
  }
}