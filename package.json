{
  "name": "bamboo-app",
  "private": true,
  "scripts": {
    "dev": "granite dev",
    "android:connect": "$HOME/Library/Android/sdk/platform-tools/adb reverse tcp:8081 tcp:8081 && $HOME/Library/Android/sdk/platform-tools/adb reverse tcp:5173 tcp:5173",
    "android:open": "adb shell am start -a android.intent.action.VIEW -d \"intoss://bamboo-app\"",
    "android:devices": "adb devices -l",
    "build": "granite build",
    "debug:android": "bash scripts/debug-android.sh",
    "debug:android:logs": "bash scripts/debug-android-logs.sh",
    "debug:android:errors": "bash scripts/debug-android-errors.sh",
    "test": "jest --passWithNoTests",
    "test:checklist": "jest --testPathPattern=release-checklist --passWithNoTests",
    "checklist:bundle": "npm run build && npm run test:checklist",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write",
    "postinstall": "node scripts/patch-granite-rn.js"
  },
  "dependencies": {
    "@apps-in-toss/framework": "^1.11.2",
    "@granite-js/native": "0.1.34",
    "@granite-js/plugin-env": "^0.1.34",
    "@granite-js/react-native": "^0.1.34",
    "@toss/tds-react-native": "^1.3.8",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "firebase": "^12.9.0",
    "react": "18.2.0",
    "react-native": "0.72.6",
    "stream-browserify": "^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "7.28.5",
    "@babel/runtime": "7.28.4",
    "@biomejs/biome": "^1.9.4",
    "@granite-js/plugin-hermes": "0.1.34",
    "@granite-js/plugin-router": "0.1.34",
    "@testing-library/react-native": "^12.9.0",
    "@types/babel__core": "^7.20.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/react": "18.3.3",
    "babel-preset-granite": "0.1.34",
    "jest": "^29.7.0",
    "patch-package": "^8.0.1",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.8.3"
  }
}
